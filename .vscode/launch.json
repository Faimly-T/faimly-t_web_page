{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch via Live Server (Port 5500)",
      "type": "chrome",
      "request": "launch",
      "url": "http://127.0.0.1:5500/index.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Launch index.html (Local File)",
      "type": "chrome",
      "request": "launch",
      "file": "${workspaceFolder}/index.html"
    }
  ]
}
